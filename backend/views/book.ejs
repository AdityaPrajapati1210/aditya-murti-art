<%- include('partials/header') %>

<section class="py-16 px-6" style="background-color: var(--studio-cream); min-height: 100vh;">
  <div class="max-w-5xl" id="booking-form-wrapper">
    <div class="form-grid grid">
      
      <!-- 1. Left Information Column -->
      <div class="form-info-column">
        <div>
          <p style="color: var(--studio-gold); font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 0.5rem;">Work In Progress</p>
          <h1>Book a Design Consultation</h1>
          <div class="divider"></div>
        </div>
        
        <p>
          Every clay sculpture is crafted strictly to customer specifications. Schedule a free design consultation to discuss sizes, clay types (baked terracotta, riverbank mitti, etc.), timeline, and delivery.
        </p>

        <div class="form-info-list">
          <div class="form-info-list-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>Confirmations call within 24 hours</span>
          </div>
          <div class="form-info-list-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <span>HTML email summary delivered to inbox</span>
          </div>
          <div class="form-info-list-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            <span>No commercial molds - 100% handmade art</span>
          </div>
        </div>

        <div class="help-box">
          <p class="title">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            How does custom pricing work?
          </p>
          <p>
            Since clay quality, structural steel/wood armature, detailing hours, and shipping weight vary widely, Jeetendra Prajapati provides a detailed estimate during your phone/video consultation based on the parameters submitted.
          </p>
        </div>
      </div>

      <!-- 2. Form Fields Column -->
      <div class="form-box">
        <form id="booking-form">
          <div class="form-group-row">
            <!-- Full Name -->
            <div class="form-group">
              <label for="fullName">Full Name *</label>
              <input type="text" id="fullName" placeholder="e.g. Aditya Prajapati" required />
            </div>

            <!-- Phone Number -->
            <div class="form-group">
              <label for="phoneNumber">Phone Number *</label>
              <input type="tel" id="phoneNumber" placeholder="e.g. +91 98765 43210" required />
            </div>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label for="email">Email Address *</label>
            <input type="email" id="email" placeholder="e.g. aditya@example.com" required />
          </div>

          <div class="form-group-row">
            <!-- Sculpture Type -->
            <div class="form-group">
              <label for="sculptureType">Sculpture Type *</label>
              <select id="sculptureType" required>
                <% 
                  const options = [
                    'Religious Murti',
                    'Ganesha',
                    'Durga Maa',
                    'Kali Maa',
                    'Krishna',
                    'Saraswati',
                    'Lakshmi',
                    'Vishwakarma',
                    'Other'
                  ];
                %>
                <% options.forEach(opt => { %>
                  <option value="<%= opt %>" <%= preselectService === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>

            <!-- Preferred Size -->
            <div class="form-group">
              <label for="preferredSize">Preferred Size (e.g. 2 Feet) *</label>
              <input type="text" id="preferredSize" placeholder="e.g. 3 Feet / 18 Inches" required />
            </div>
          </div>

          <div class="form-group-row">
            <!-- Budget -->
            <div class="form-group">
              <label for="budget">Estimated Budget (INR / details) *</label>
              <input type="text" id="budget" placeholder="e.g. ₹15,000 / Flexible" required />
            </div>

            <!-- Meeting Date -->
            <div class="form-group">
              <label for="meetingDate">Preferred Date *</label>
              <input type="date" id="meetingDate" required />
            </div>
          </div>

          <!-- Requirements Message -->
          <div class="form-group">
            <label for="message">Sculpture Requirements & Poses *</label>
            <textarea id="message" rows="4" placeholder="Describe details: Pose, paint finish (organic vs gloss), timeline dependencies, or visual references." required><%= preselectTitle ? `I am interested in ordering a sculpture similar to: "${preselectTitle}".` : '' %></textarea>
          </div>

          <button type="submit" class="btn btn-chocolate" style="width: 100%; padding: 0.9rem;">
            Request Free Consultation
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  // Set minimum date constraint to today dynamically on client load
  document.addEventListener('DOMContentLoaded', () => {
    const today = new Date();
    const yyyy = today.getFullYear();
    let mm = today.getMonth() + 1;
    let dd = today.getDate();
    if (mm < 10) mm = `0${mm}`;
    if (dd < 10) dd = `0${dd}`;
    
    const minDateInput = document.getElementById('meetingDate');
    if (minDateInput) {
      minDateInput.min = `${yyyy}-${mm}-${dd}`;
    }
  });
</script>

<%- include('partials/footer') %>
