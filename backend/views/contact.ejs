<%- include('partials/header') %>

<section class="py-16 px-6" style="background-color: var(--studio-cream); min-height: 100vh;">
  <div class="max-w-6xl" style="display: flex; flex-direction: column; gap: 4rem;">
    
    <!-- Header -->
    <div class="section-header">
      <p class="sub">Get In Touch</p>
      <h2>Contact the Aditya Murti Art</h2>
      <div class="divider"></div>
      <p class="desc">Reach out for custom order questions, workshop visits, or general questions about traditional clay art.</p>
    </div>

    <!-- Contact Content Grid -->
    <div class="form-grid grid">
      
      <!-- 1. Left Contact Details Column -->
      <div class="form-info-column">
        
        <div class="contact-details-box">
          <h2>Studio Details</h2>
          <div class="divider"></div>

          <div class="contact-list">
            
            <div class="contact-list-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <div>
                <h3>Physical Studio Address</h3>
                <p style="color: rgba(253, 251, 247, 0.85);">Bhiti Mau, Uttar Pradesh - 275101, India</p>
              </div>
            </div>

            <div class="contact-list-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              <div>
                <h3>Phone Number</h3>
                <a href="tel:+919889554521" style="color: rgba(253, 251, 247, 0.85); font-weight: 300;">+91 98895 54521</a>
              </div>
            </div>

            <div class="contact-list-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <div>
                <h3>Email</h3>
                <a href="https://mail.google.com/mail/?view=cm&fs=1&to=jeetendraprajapati04@gmail.com" target="_blank" rel="noopener noreferrer" style="color: rgba(253, 251, 247, 0.85); font-weight: 300;">jeetendraprajapati04@gmail.com</a>
              </div>
            </div>

          </div>
        </div>

        <!-- Simulated Map Placeholder -->
        <div class="map-placeholder-box">
          <div class="map-bg" style="background-image: url('https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=600');"></div>
          <div class="map-content">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            <h3>Bhiti Mau, Mau</h3>
            <p>Uttar Pradesh, India</p>
            <div style="margin-top: 0.75rem;">
              <a href="https://maps.app.goo.gl/hdnsjytrczXEGbeH8"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-chocolate"
                style="padding: 0.5rem 1rem; font-size: 0.75rem;">
                Open Google Maps
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- 2. Right Contact Message Form -->
      <div class="form-box">
        <h2 style="font-family: var(--font-playfair); font-size: 1.5rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--studio-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          Send a Message
        </h2>

        <form id="contact-form">
          
          <!-- Full Name -->
          <div class="form-group">
            <label for="fullName">Full Name</label>
            <input type="text" id="fullName" placeholder="e.g. Aditya Prajapati" required />
          </div>

          <!-- Email -->
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" placeholder="e.g. aditya@example.com" required />
          </div>

          <!-- Subject -->
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" placeholder="e.g. Order Inquiry / Workshop Visit" required />
          </div>

          <!-- Message -->
          <div class="form-group">
            <label for="message">Message Details</label>
            <textarea id="message" rows="5" placeholder="Write your message here..." required></textarea>
          </div>

          <button type="submit" class="btn btn-chocolate" style="width: 100%; padding: 0.9rem;">
            Send Inquiry
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>
