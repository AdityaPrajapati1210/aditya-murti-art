<%- include('partials/header') %>

<section class="py-16 px-6" style="background-color: var(--studio-cream); min-height: 80vh; display: flex; align-items: center; justify-content: center;">
  <div class="max-w-md w-full" style="width: 100%;">
    
    <div class="form-box" style="display: flex; flex-direction: column; gap: 1.5rem;">
      
      <!-- Icon & Branding Header -->
      <div style="text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
        <div class="login-header-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        <h1 style="font-size: 1.5rem;">Admin Portal Access</h1>
        <p class="badge-gold" style="font-size: 10px; padding: 0.25rem 0.625rem; font-weight: 500;">Jeetendra Prajapati Clay Art</p>
        <div style="height: 1px; width: 3rem; background: rgba(212,175,55,0.3); margin-top: 0.5rem;"></div>
      </div>

      <!-- Form -->
      <form id="login-form">
        <!-- Username -->
        <div class="form-group">
          <label for="username">Username</label>
          <div style="position: relative; display: flex; align-items: center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(45,27,20,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position: absolute; left: 1rem;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            <input type="text" id="username" placeholder="Enter username" style="padding-left: 2.75rem;" required />
          </div>
        </div>

        <!-- Password -->
        <div class="form-group" style="margin-bottom: 2rem;">
          <label for="password">Password</label>
          <div class="password-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(45,27,20,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); z-index: 10;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            <input type="password" id="password" placeholder="Enter password" style="padding-left: 2.75rem; padding-right: 2.75rem;" required />
            <button type="button" class="password-toggle-btn" id="toggle-password" aria-label="Toggle password visibility">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-chocolate" style="width: 100%; padding: 0.8rem;">
          Log In
        </button>
      </form>

      <p style="text-align: center; font-size: 11px; color: rgba(45,27,20,0.45); font-weight: 300;">
        This portal is reserved strictly for studio administrators. Unauthorized access attempts are monitored.
      </p>

    </div>

  </div>
</section>

<%- include('partials/footer') %>
