# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local MongoDB: mongodb://localhost:27017/clay_art_studio
# Atlas MongoDB: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb://localhost:27017/clay_art_studio

# JWT Session Authentication Secret
JWT_SECRET=your_jwt_secret_minimum_32_chars_long

# Cloudinary Integration (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Service Configuration (Nodemailer SMTP)
# For Gmail: Use smtp.gmail.com with port 587 (EMAIL_SECURE=false) and an App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM_NAME=Jeetendra Prajapati Clay Art Studio

# Notification Recipient (Where the admin receives email alerts)
ADMIN_RECEIVER_EMAIL=admin_notifications@example.com

# Seeding Administrator Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=jeetendra@clay123
